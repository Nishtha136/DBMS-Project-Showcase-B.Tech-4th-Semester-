# Aiven MySQL connection (same DATABASE_URL the Express backend used)
DATABASE_URL=mysql://avnadmin:PASSWORD@HOST:PORT/studylab-dbms

# HTTP server port
PORT=3000

# JWT signing secret -- MUST match what the existing JWTs were signed with,
# otherwise old tokens (Android sessions) won't verify.
JWT_SECRET=studylabs_jwt_secret_change_this_in_production_use_long_random_string

# Redis URL for the cache layer. Optional -- if unreachable the wrapper
# silently no-ops and every endpoint hits MySQL on every request.
REDIS_URL=redis://localhost:6379/0
