<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:background="?attr/selectableItemBackground">

    <View
        android:id="@+id/subjectColorDot"
        android:layout_width="14dp"
        android:layout_height="14dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tvSubjectRowName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/tmr_text_primary" />

        <TextView
            android:id="@+id/tvSubjectRowTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/tmr_text_muted" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSubjectCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/tmr_primary_blue"
        android:visibility="gone" />
</LinearLayout>
