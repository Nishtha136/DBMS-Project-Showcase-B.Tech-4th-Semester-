<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Experiment"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Name your experiment and add 3 check-in questions."
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHOOSE A MARK"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/primary_blue"
        android:layout_marginBottom="10dp"/>

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView android:id="@+id/icon_flask"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="◆" android:textSize="20sp" android:gravity="center"
            android:background="@drawable/bg_icon_selected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_muscle"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="▲" android:textSize="20sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_brain"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="■" android:textSize="20sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_bolt"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="●" android:textSize="20sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_sunrise"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="Δ" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_book"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="Σ" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_run"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="∞" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView android:id="@+id/icon_sleep"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="Ω" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_meditate"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="≡" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_target"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="⊕" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_timer"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="⊗" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_leaf"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="◎" android:textSize="22sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_bulb"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="μ" android:textSize="24sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"
            android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/icon_art"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="46dp"
            android:text="λ" android:textSize="24sp" android:gravity="center"
            android:background="@drawable/bg_icon_unselected"/>
    </LinearLayout>

    <!-- Title field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EXPERIMENT TITLE"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/primary_blue"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_experiment_title"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_details_btn"
        android:paddingHorizontal="14dp"
        android:hint="e.g. Morning Cold Shower"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:singleLine="true"
        android:inputType="textCapSentences"
        android:layout_marginBottom="18dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E8EBEF"
        android:layout_marginBottom="18dp"/>

    <!-- Q1 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUESTION 1"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/primary_blue"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_question1"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_details_btn"
        android:paddingHorizontal="14dp"
        android:hint="e.g. How focused did you feel today?"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:singleLine="true"
        android:inputType="textCapSentences"
        android:layout_marginBottom="14dp"/>

    <!-- Q2 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUESTION 2"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/primary_blue"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_question2"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_details_btn"
        android:paddingHorizontal="14dp"
        android:hint="e.g. How was your energy level?"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:singleLine="true"
        android:inputType="textCapSentences"
        android:layout_marginBottom="14dp"/>

    <!-- Q3 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUESTION 3"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/primary_blue"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_question3"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_details_btn"
        android:paddingHorizontal="14dp"
        android:hint="e.g. Would you repeat this tomorrow?"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:singleLine="true"
        android:inputType="textCapSentences"
        android:layout_marginBottom="18dp"/>

    <!-- Goal Days -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DURATION (DAYS)"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/primary_blue"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/et_goal_days"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_details_btn"
        android:paddingHorizontal="14dp"
        android:hint="e.g. 7, 14, 21 or 30"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:singleLine="true"
        android:inputType="number"
        android:layout_marginBottom="24dp"/>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:background="@drawable/bg_details_btn"
            android:gravity="center"
            android:text="Cancel"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <View android:layout_width="12dp" android:layout_height="1dp"/>

        <TextView
            android:id="@+id/btn_dialog_create"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:background="@drawable/bg_check_in_btn"
            android:gravity="center"
            android:text="Create"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>

</ScrollView>
