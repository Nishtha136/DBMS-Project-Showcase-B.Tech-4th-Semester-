<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tmr_page_bg">

    <!-- ═══ HEADER BAR ═══ -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:background="?selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/tmr_text_secondary"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Study Timer"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:textColor="@color/tmr_text_primary" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:background="?selectableItemBackgroundBorderless"
            android:src="@drawable/ic_tmr_menu_dots"
            android:contentDescription="Menu" />
    </LinearLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/tmr_divider"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══ MAIN CONTENT ═══ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- A. SUBJECT SELECTOR CARD -->
            <LinearLayout
                android:id="@+id/subjectCard"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_tmr_subject_card"
                android:elevation="1dp">

                <View
                    android:id="@+id/subjectDot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/bg_cal_dot_orange" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT SUBJECT"
                        android:textSize="14sp"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"
                        android:textColor="@color/tmr_text_muted" />

                    <TextView
                        android:id="@+id/tvSubjectName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Physics"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/tmr_text_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnChangeSubject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/tmr_primary_blue" />
            </LinearLayout>

            <!-- B. CIRCULAR TIMER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center">

                <com.example.studylab.CircularTimerView
                    android:id="@+id/circularTimer"
                    android:layout_width="240dp"
                    android:layout_height="304dp"
                    android:layout_gravity="center_horizontal" />
            </FrameLayout>

            <!-- C. ACTION BUTTONS ROW (Pause/Resume only) -->
            <LinearLayout
                android:id="@+id/btnPause"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_tmr_btn_outline"
                android:alpha="0.5">

                <ImageView
                    android:id="@+id/icPause"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_tmr_pause" />

                <TextView
                    android:id="@+id/tvPause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pause"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/tmr_primary_blue"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- D. START STUDYING CTA -->
            <LinearLayout
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                android:gravity="center"
                android:background="@drawable/bg_tmr_btn_primary"
                android:elevation="6dp">

                <TextView
                    android:id="@+id/tvStartBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start Studying"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <!-- E. FOCUS MODE BANNER -->
            <LinearLayout
                android:id="@+id/focusBanner"
                android:layout_width="match_parent"
                android:layout_height="69dp"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_tmr_focus_active"
                android:elevation="4dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="37dp"
                    android:background="@drawable/bg_tmr_focus_icon">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="21dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_tmr_lock" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvFocusTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Focus Mode Active"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tvFocusSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distracting apps are blocked"
                        android:textSize="12sp"
                        android:textColor="@color/tmr_text_light" />
                </LinearLayout>

                <ImageView
                    android:layout_width="8dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_cal_chevron_right"
                    app:tint="@color/tmr_text_disabled" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══ BOTTOM NAV BAR ═══ -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="111dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nav bar background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="81dp"
            android:layout_gravity="bottom"
            android:background="@color/tmr_nav_bg"
            android:elevation="2dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="81dp"
            android:background="@color/tmr_divider" />

        <!-- Nav items row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="81dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:elevation="3dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navItemHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/tmr_text_disabled" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOME"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.04"
                    android:textAllCaps="true"
                    android:textColor="@color/tmr_text_disabled"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Calendar -->
            <LinearLayout
                android:id="@+id/navItemCalendar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/tmr_text_disabled" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CALENDAR"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.04"
                    android:textAllCaps="true"
                    android:textColor="@color/tmr_text_disabled"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Timer (raised center - spacer) -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="35dp"
                android:layout_weight="0"
                android:clipChildren="false"
                android:clipToPadding="false" />

            <!-- Vault -->
            <LinearLayout
                android:id="@+id/navItemVault"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_vault"
                    app:tint="@color/tmr_text_disabled" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VAULT"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.04"
                    android:textAllCaps="true"
                    android:textColor="@color/tmr_text_disabled"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Labs -->
            <LinearLayout
                android:id="@+id/navItemLabs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_labs"
                    app:tint="@color/tmr_text_disabled" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LABS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.04"
                    android:textAllCaps="true"
                    android:textColor="@color/tmr_text_disabled"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Raised center timer button (floats above bar) -->
        <LinearLayout
            android:id="@+id/navItemTimer"
            android:layout_width="56dp"
            android:layout_height="75dp"
            android:layout_gravity="center_horizontal|top"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipChildren="false"
            android:elevation="6dp">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_tmr_nav_raised">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_tmr_stopwatch" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIMER"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="-0.04"
                android:textAllCaps="true"
                android:textColor="@color/tmr_text_disabled"
                android:fontFamily="@font/lexend"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
