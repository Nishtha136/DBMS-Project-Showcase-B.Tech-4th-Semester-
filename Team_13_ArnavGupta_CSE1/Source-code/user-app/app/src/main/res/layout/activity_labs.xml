<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:paddingBottom="12dp"
            android:background="@color/background_color">

            <ImageView
                android:id="@+id/menu_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_chevron_down"
                android:rotation="90"
                android:padding="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Labs"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_bell"/>
        </RelativeLayout>

        <!-- Tab Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <TextView
                android:id="@+id/tab_experiments"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Experiments"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"
                android:textColor="@color/primary_blue"/>

            <TextView
                android:id="@+id/tab_analytics"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Analytics"
                android:gravity="center"
                android:textSize="14sp"
                android:paddingBottom="12dp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tab_dashboard"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:gravity="center"
                android:textSize="14sp"
                android:paddingBottom="12dp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- Tab indicator line -->
        <View
            android:id="@+id/tab_indicator"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#E8EBEF"/>

        <!-- Tab Content Frame -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- ═══════════════════════════════════════════════ -->
            <!-- EXPERIMENTS TAB                                 -->
            <!-- ═══════════════════════════════════════════════ -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/section_experiments"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="148dp"
                android:clipToPadding="false"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp">

                    <!-- Active header row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active"
                            android:textSize="18sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tv_running_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_badge_blue"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="0 RUNNING"
                            android:textColor="@color/badge_blue_text"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <!-- Container for dynamic experiment cards -->
                    <LinearLayout
                        android:id="@+id/active_experiments_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <!-- Empty state (shown when no experiments) -->
                    <LinearLayout
                        android:id="@+id/tv_active_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="48dp"
                        android:visibility="visible">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔬"
                            android:textSize="40sp"
                            android:layout_marginBottom="12dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No experiments yet"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Tap + New Experiment to get started"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- ANALYTICS TAB                                   -->
            <!-- ═══════════════════════════════════════════════ -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/section_analytics"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp">

                    <!-- Section title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Experiment Analytics"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Dynamic analytics cards — one per experiment -->
                    <LinearLayout
                        android:id="@+id/analytics_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <!-- Empty state -->
                    <LinearLayout
                        android:id="@+id/tv_analytics_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="48dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="40sp"
                            android:layout_marginBottom="12dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No data yet"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Create an experiment and check in to see analytics"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- DASHBOARD TAB                                   -->
            <!-- ═══════════════════════════════════════════════ -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/section_dashboard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Activity History Card (calendar grid) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp"
                        android:elevation="1dp">

                        <!-- Month navigation row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:id="@+id/btn_prev_month"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_chevron_down"
                                android:rotation="90"
                                android:padding="2dp"/>

                            <TextView
                                android:id="@+id/tv_dashboard_month"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:text="April 2026"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>

                            <ImageView
                                android:id="@+id/btn_next_month"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_chevron_down"
                                android:rotation="-90"
                                android:padding="2dp"/>
                        </RelativeLayout>

                        <!-- Day of week headers -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="M" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="T" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="W" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="T" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="F" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="S" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="S" android:gravity="center" android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                        </LinearLayout>

                        <!-- Dynamic calendar grid — built in code -->
                        <LinearLayout
                            android:id="@+id/dashboard_grid_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <!-- Legend -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="14dp">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_grid_empty" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="None" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_marginEnd="10dp"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_grid_filled" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1 check-in" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_marginEnd="10dp"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:id="@+id/legend_multi" android:layout_marginEnd="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2+ check-ins" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card"
                            android:orientation="vertical"
                            android:padding="18dp"
                            android:layout_marginEnd="8dp"
                            android:elevation="1dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL CHECK-INS"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:textColor="@color/text_hint"/>
                            <TextView
                                android:id="@+id/tv_dash_total_checkins"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card"
                            android:orientation="vertical"
                            android:padding="18dp"
                            android:layout_marginStart="8dp"
                            android:elevation="1dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE EXPS"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:textColor="@color/text_hint"/>
                            <TextView
                                android:id="@+id/tv_dash_active_exps"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/text_primary"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Experiment list in dashboard -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Experiment Timeline"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp"/>

                    <!-- Dynamic timeline cards -->
                    <LinearLayout
                        android:id="@+id/dashboard_timeline_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <TextView
                        android:id="@+id/tv_dashboard_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No experiments to show. Create one from the Experiments tab!"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:paddingVertical="16dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- + New Experiment FAB -->
            <TextView
                android:id="@+id/btn_new_experiment"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="95dp"
                android:background="@drawable/bg_dark_button"
                android:gravity="center"
                android:text="+ New Experiment"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:elevation="8dp"/>

        </FrameLayout>
    </LinearLayout>

    <!-- Bottom Navigation (floating) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/white"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:paddingBottom="12dp"
            android:baselineAligned="false"
            android:elevation="8dp">

            <LinearLayout
                android:id="@+id/navItemHome"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_home"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="HOME" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navItemCalendar"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="CALENDAR" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

            <!-- Spacer for FAB area -->
            <View android:id="@+id/navItemTimer" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>

            <LinearLayout
                android:id="@+id/navItemVault"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_vault"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="VAULT" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/nav_inactive"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navItemLabs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_labs"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="LABS" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primary_blue"/>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
