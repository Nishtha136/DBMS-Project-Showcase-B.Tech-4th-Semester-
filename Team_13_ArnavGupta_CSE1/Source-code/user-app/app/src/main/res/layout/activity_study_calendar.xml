<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cal_page_bg">

    <!-- ═══ TOP NAV BAR ═══ -->
    <LinearLayout
        android:id="@+id/topNav"
        android:layout_width="0dp"
        android:layout_height="61dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/cal_topnav_bg"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="@color/cal_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Study Calendar"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/cal_text_primary"
            android:fontFamily="@font/lexend" />

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="36dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="bottom"
                android:padding="6dp"
                android:src="@drawable/ic_bell"
                android:contentDescription="Notifications"
                app:tint="@color/cal_text_primary" />

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_cal_dot_red" />
        </FrameLayout>
    </LinearLayout>

    <!-- Divider below nav -->
    <View
        android:id="@+id/navDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/cal_divider"
        app:layout_constraintTop_toBottomOf="@id/topNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══ SCROLLABLE CONTENT ═══ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/navDivider"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- ═══ SEGMENTED TOGGLE ═══ -->
            <LinearLayout
                android:id="@+id/toggleContainer"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="horizontal"
                android:padding="4dp"
                android:background="@drawable/bg_cal_toggle_container">

                <TextView
                    android:id="@+id/tabHeatmap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Heatmap Mode"
                    android:textSize="14sp"
                    android:textColor="@color/cal_primary_blue"
                    android:textStyle="bold"
                    android:fontFamily="@font/lexend"
                    android:background="@drawable/bg_cal_toggle_active"
                    android:elevation="1dp" />

                <TextView
                    android:id="@+id/tabAssessment"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Assessment Mode"
                    android:textSize="14sp"
                    android:textColor="@color/cal_text_muted"
                    android:fontFamily="@font/lexend" />
            </LinearLayout>

            <!-- ═══ MONTH SELECTOR ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp">

                <ImageView
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_cal_chevron_left"
                    android:contentDescription="Previous month" />

                <TextView
                    android:id="@+id/tvMonthYear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="March 2025"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/cal_text_primary"
                    android:fontFamily="@font/lexend" />

                <ImageView
                    android:id="@+id/btnNextMonth"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_cal_chevron_right"
                    android:contentDescription="Next month" />
            </LinearLayout>

            <!-- ═══ CALENDAR CARD ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_cal_card"
                android:elevation="1dp">

                <!-- Day-of-week headers -->
                <LinearLayout
                    android:id="@+id/dayHeaders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <!-- 7 header TextViews added programmatically -->
                </LinearLayout>

                <!-- Calendar grid container -->
                <GridLayout
                    android:id="@+id/calendarGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="7"
                    android:useDefaultMargins="false" />

                <!-- Legend - Heatmap -->
                <LinearLayout
                    android:id="@+id/legendHeatmap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end|center_vertical"
                    android:paddingTop="8dp"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Less"
                        android:textSize="10sp"
                        android:textColor="@color/cal_text_muted"
                        android:fontFamily="@font/lexend"
                        android:layout_marginEnd="8dp" />

                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/bg_cal_heat_0"
                        android:layout_marginEnd="4dp" />
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/bg_cal_heat_2"
                        android:layout_marginEnd="4dp" />
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/bg_cal_heat_3"
                        android:layout_marginEnd="4dp" />
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/bg_cal_heat_5"
                        android:layout_marginEnd="4dp" />
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/bg_cal_heat_6"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="More"
                        android:textSize="10sp"
                        android:textColor="@color/cal_text_muted"
                        android:fontFamily="@font/lexend" />
                </LinearLayout>

                <!-- Legend - Assessment -->
                <LinearLayout
                    android:id="@+id/legendAssessment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@drawable/bg_cal_cell_assessment" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Assessment Due"
                            android:textSize="10sp"
                            android:textColor="@color/cal_text_muted"
                            android:fontFamily="@font/lexend"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="16dp" />

                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@drawable/bg_cal_cell_today" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today"
                            android:textSize="10sp"
                            android:textColor="@color/cal_text_muted"
                            android:fontFamily="@font/lexend"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@drawable/bg_cal_cell_task" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Task Due"
                            android:textSize="10sp"
                            android:textColor="@color/cal_text_muted"
                            android:fontFamily="@font/lexend"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="16dp" />

                        <View
                            android:id="@+id/legendBothSwatch"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginEnd="6dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Both"
                            android:textSize="10sp"
                            android:textColor="@color/cal_text_muted"
                            android:fontFamily="@font/lexend" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ STATS ROW ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_cal_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Study Time"
                        android:textSize="12sp"
                        android:textColor="@color/cal_text_muted"
                        android:fontFamily="@font/lexend" />

                    <TextView
                        android:id="@+id/tvTotalStudyTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0h 0m"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/cal_text_primary"
                        android:fontFamily="@font/space_mono" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_cal_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg. Completion"
                        android:textSize="12sp"
                        android:textColor="@color/cal_text_muted"
                        android:fontFamily="@font/lexend" />

                    <TextView
                        android:id="@+id/tvAvgCompletion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0%"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/cal_text_primary"
                        android:fontFamily="@font/space_mono" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ BOTTOM SHEET (always visible panel) ═══ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <!-- Heatmap Mode Bottom Sheet -->
                <LinearLayout
                    android:id="@+id/sheetHeatmap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cal_bottom_sheet"
                    android:paddingTop="16dp"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="24dp"
                    android:elevation="4dp"
                    android:visibility="visible">

                    <!-- Handle -->
                    <View
                        android:layout_width="48dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_cal_handle" />

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="24dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvHeatmapDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="March 10, 2025"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/cal_text_primary"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:id="@+id/tvHeatmapSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3 sessions scheduled"
                                android:textSize="14sp"
                                android:textColor="@color/cal_text_muted"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@drawable/bg_cal_add_btn">
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_cal_plus" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Session list container -->
                    <LinearLayout
                        android:id="@+id/heatmapSessionList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp" />
                </LinearLayout>

                <!-- Assessment Mode Bottom Sheet -->
                <LinearLayout
                    android:id="@+id/sheetAssessment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cal_bottom_sheet"
                    android:paddingTop="16dp"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="24dp"
                    android:elevation="4dp"
                    android:visibility="gone">

                    <!-- Handle -->
                    <View
                        android:layout_width="48dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_cal_handle" />

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="24dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAssessmentDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="March 10, 2025"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/cal_text_primary"
                                android:fontFamily="@font/lexend" />

                            <TextView
                                android:id="@+id/tvAssessmentSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2 assessments due"
                                android:textSize="14sp"
                                android:textColor="@color/cal_text_muted"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_cal_add_btn">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_cal_edit_calendar" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Assessment list container -->
                    <LinearLayout
                        android:id="@+id/assessmentList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp" />

                    <!-- Action buttons -->
                    <LinearLayout
                        android:id="@+id/actionButtons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <LinearLayout
                            android:id="@+id/btnAddAssessment"
                            android:layout_width="0dp"
                            android:layout_height="64dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_cal_action_orange">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_cal_plus_white"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add\nAssessment"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/white"
                                android:textAlignment="center"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnAddTask"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_gravity="center_vertical"
                            android:background="@drawable/bg_cal_action_gray">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/ic_cal_plus_dark"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Task"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/cal_text_task"
                                android:fontFamily="@font/lexend" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══ BOTTOM NAV BAR ═══ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="81dp"
        android:orientation="horizontal"
        android:background="@color/cal_nav_bg"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navItemHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_home"
                app:tint="@color/cal_text_disabled" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOME"
                android:textSize="10sp"
                android:textColor="@color/cal_text_disabled"
                android:fontFamily="@font/lexend"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Calendar -->
        <LinearLayout
            android:id="@+id/navItemCalendar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/cal_text_disabled" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CALENDAR"
                android:textSize="10sp"
                android:textColor="@color/cal_text_disabled"
                android:fontFamily="@font/lexend"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Timer -->
        <LinearLayout
            android:id="@+id/navItemTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_timer"
                app:tint="@color/cal_text_disabled" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIMER"
                android:textSize="10sp"
                android:textColor="@color/cal_text_disabled"
                android:fontFamily="@font/lexend"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Vault -->
        <LinearLayout
            android:id="@+id/navItemVault"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_vault"
                app:tint="@color/cal_text_disabled" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VAULT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/cal_text_disabled"
                android:fontFamily="@font/lexend"
                android:letterSpacing="-0.03"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Labs -->
        <LinearLayout
            android:id="@+id/navItemLabs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_labs"
                app:tint="@color/cal_text_disabled" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LABS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/cal_text_disabled"
                android:fontFamily="@font/lexend"
                android:letterSpacing="-0.03"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider above bottom nav -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/cal_divider"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
