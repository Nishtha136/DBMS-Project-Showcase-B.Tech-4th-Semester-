{
  "name": "biz-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"nodemon backend/server.js\" \"vite --config vite.config.js\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:import": "mysql -u $DB_USER -p$DB_PASSWORD $DB_NAME < backend/database/schema.sql",
    "db:seed": "mysql -u $DB_USER -p$DB_PASSWORD $DB_NAME < backend/database/seed.sql",
    "start:backend": "node backend/server.js",
    "start:frontend": "vite --config vite.config.js",
    "test:smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  }
}
