  <script src="/js/main.js"></script>
  <script>
    const revealElements = document.querySelectorAll('.h-feat-card, .h-testi-card, .h-step, .h-hostel-card, .h-story-col, .h-stat');
    revealElements.forEach((el, index) => {
      el.classList.add('reveal-up');
      el.style.transitionDelay = `${Math.min(index * 0.04, 0.38)}s`;
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('in-view');
      });
    }, { threshold: 0.12 });
    revealElements.forEach((el) => io.observe(el));

    const nav = document.getElementById('homeNav');
    const onScroll = () => nav.classList.toggle('nav-scrolled', window.scrollY > 18);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const menuToggle = document.getElementById('menuToggle');
    const menuClose = document.getElementById('menuClose');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileMenuBackdrop = document.getElementById('mobileMenuBackdrop');
    const closeMenu = () => {
      mobileMenu.classList.remove('open');
      mobileMenuBackdrop.classList.remove('open');
      menuToggle.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('menu-open');
    };
    const openMenu = () => {
      mobileMenu.classList.add('open');
      mobileMenuBackdrop.classList.add('open');
      menuToggle.setAttribute('aria-expanded', 'true');
      mobileMenu.setAttribute('aria-hidden', 'false');
      document.body.classList.add('menu-open');
    };
    if (menuToggle) menuToggle.addEventListener('click', () => mobileMenu.classList.contains('open') ? closeMenu() : openMenu());
    if (menuClose) menuClose.addEventListener('click', closeMenu);
    if (mobileMenuBackdrop) mobileMenuBackdrop.addEventListener('click', closeMenu);
    document.querySelectorAll('.mobile-menu-link').forEach((link) => link.addEventListener('click', closeMenu));

    const photoWrap = document.querySelector('.h-photo-wrap');
    const blobs = document.querySelectorAll('.h-bg-blob');
    let mouseX = 0;
    let mouseY = 0;
    let scrollShift = 0;
    const paintHeroTransform = () => {
      if (!photoWrap) return;
      photoWrap.style.transform = `rotateY(${mouseX * 4}deg) rotateX(${mouseY * -3}deg) translateY(${scrollShift}px)`;
    };
    if (photoWrap && window.matchMedia('(min-width: 1025px)').matches) {
      document.addEventListener('mousemove', (event) => {
        mouseX = (event.clientX / window.innerWidth - 0.5);
        mouseY = (event.clientY / window.innerHeight - 0.5);
        paintHeroTransform();
        blobs.forEach((blob, idx) => {
          const speed = (idx + 1) * 8;
          blob.style.transform = `translate(${mouseX * speed}px, ${mouseY * speed}px)`;
        });
      });
      window.addEventListener('scroll', () => {
        scrollShift = Math.min(window.scrollY * 0.08, 28);
        paintHeroTransform();
      }, { passive: true });
    }

    const particlesRoot = document.getElementById('heroParticles');
    if (particlesRoot) {
      for (let i = 0; i < 18; i++) {
        const dot = document.createElement('span');
        dot.className = 'h-particle';
        dot.style.left = `${Math.random() * 100}%`;
        dot.style.top = `${Math.random() * 100}%`;
        dot.style.animationDelay = `${Math.random() * 4}s`;
        dot.style.animationDuration = `${3 + Math.random() * 4}s`;
        particlesRoot.appendChild(dot);
      }
    }

    document.querySelectorAll('.h-btn-primary, .h-btn-ghost, .hn-register, .h-cta-btn-primary, .h-cta-btn-ghost').forEach((btn) => {
      btn.addEventListener('click', function (event) {
        const circle = document.createElement('span');
        circle.className = 'btn-ripple';
        const rect = this.getBoundingClientRect();
        circle.style.left = `${event.clientX - rect.left}px`;
        circle.style.top = `${event.clientY - rect.top}px`;
        this.appendChild(circle);
        setTimeout(() => circle.remove(), 500);
      });
    });
  </script>
