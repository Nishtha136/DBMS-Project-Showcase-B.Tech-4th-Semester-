<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= hostel.hostel_name %> — UniStay Admin
  </title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-9K0Vj6eiGLRullBxqN5G2LNYTtQ6XnF7/s1UxMkFYS9qC6gzZDhJjVxV5XJ0FzNYkXSLDh7W4t9F1Y4RLd2U8g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body class="dashboard-shell">
  <nav class="navbar">
    <a href="/" class="logo unistay-nav">
      <img src="/images/unistay-logo.png" alt="UniStay" class="nav-logo-img">
      UniStay
    </a>
    <div class="nav-links">
      <span class="text-muted"
        style="font-size:0.8rem; font-weight:600; background:var(--indigo-light); color:var(--indigo); padding:4px 10px; border-radius:99px;">Admin</span>
      <a href="/auth/logout" class="btn btn-ghost btn-sm">Sign out</a>
    </div>
  </nav>

  <div class="dashboard-wrapper">
    <nav class="sidebar">
      <a href="/admin/dashboard" class="sidebar-item">
        <span class="sidebar-icon"><i class="fa-solid fa-arrow-left"></i></span> Back to Dashboard
      </a>
      <a href="#" class="sidebar-item active">
        <span class="sidebar-icon"><i class="fa-solid fa-building"></i></span> Hostel Details
      </a>
    </nav>

    <main class="main-content">
      <div class="page-header" style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div>
          <h1>
            <%= hostel.hostel_name %>
          </h1>
          <p>
            <span class="badge badge-approved" style="margin-right:8px;">
              <%= hostel.hostel_type %>
            </span>
            <span class="badge" style="background:var(--surface2); color:var(--text); border:1px solid var(--border);">
              <%= hostel.gender_type %> Hostel
            </span>
          </p>
        </div>
      </div>

      <div class="section-card">
        <div class="section-card-header">
          <div>
            <h3>Room Inventory</h3>
            <p>List of all rooms, capacities, and currently allocated students.</p>
          </div>
          <input type="text" class="search-input" placeholder="Search rooms or students...">
        </div>

        <% if (rooms.length> 0) { %>
          <table class="data-table">
            <thead>
              <tr>
                <th>Room</th>
                <th>Capacity</th>
                <th>Student Name</th>
                <th>Course & Year</th>
                <th>Contact</th>
              </tr>
            </thead>
            <tbody>
              <% rooms.forEach(room=> { %>
                <tr>
                  <td style="font-weight:700;">Room <%= room.room_number %>
                  </td>
                  <td>
                    <%= room.capacity %> beds
                  </td>
                  <% if (room.student_name) { %>
                    <td style="font-weight:600;">
                      <%= room.student_name %>
                    </td>
                    <td style="color:var(--text-muted); font-size:0.85rem;">
                      <%= room.course %>, Year <%= room.year %>
                    </td>
                    <td style="color:var(--text-muted); font-size:0.85rem;">
                      <%= room.contact_number %>
                    </td>
                    <% } else { %>
                      <td colspan="3" style="color:var(--text-light); font-style:italic; font-size:0.85rem;">
                        Vacant bed slot
                      </td>
                      <% } %>
                </tr>
                <% }) %>
            </tbody>
          </table>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state-icon"><i class="fa-solid fa-building" style="color:#1e3a5f;"></i></div>
              <h4>No rooms configured</h4>
              <p>This hostel has no rooms added in the system.</p>
            </div>
            <% } %>
      </div>
    </main>
  </div>
  <script src="/js/main.js"></script>
</body>

</html>